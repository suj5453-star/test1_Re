# ========================
# Unreal Engine 5
# ========================

# 빌드 결과물 (컴파일 후 자동 생성)
Binaries/
Build/
Intermediate/
Saved/

# 파생 데이터 캐시 (용량이 매우 크고 로컬 환경 의존)
DerivedDataCache/

# 플러그인 빌드 결과물 (플러그인 소스는 포함, 빌드 결과물만 제외)
Plugins/**/Binaries/
Plugins/**/Intermediate/

# .uproject 실행에 필요한 자동 생성 파일
*.sln

# ShaderCache (플랫폼별로 자동 생성)
ShaderCache/


# ========================
# C++ / Visual Studio
# ========================

.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
*.VC.opendb

# CMake (언리얼 자체는 아니지만 혼용 시)
CMakeFiles/
CMakeCache.txt


# ========================
# Rider (JetBrains)
# ========================

.idea/
*.DotSettings.user


# ========================
